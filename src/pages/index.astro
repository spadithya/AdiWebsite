---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;

// Pull all projects from the content collection
const allProjects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.year - a.data.year);

// Group by category
function byCategory(cat: string, limit = 3) {
  return allProjects.filter((p) => p.data.category === cat).slice(0, limit);
}

const categoryBlocks = [
  {
    key: 'lab',
    num: '02',
    label: 'Lab',
    title: 'Lab',
    accent: 'work',
    lede: 'Research and engineering. The deep work.',
    projects: byCategory('lab'),
    totalCount: allProjects.filter((p) => p.data.category === 'lab').length,
    soon: 'More from the bench soon.',
  },
  {
    key: 'side-quests',
    num: '03',
    label: 'Side-quests',
    title: 'Side-quests',
    accent: 'curious',
    lede: 'Weekend ML, security, and whatever caught my attention this week.',
    projects: byCategory('side-quests'),
    totalCount: allProjects.filter((p) => p.data.category === 'side-quests').length,
    soon: 'Coming soon. Side experiments and writeups landing here.',
  },
  {
    key: 'hub',
    num: '04',
    label: 'Hub',
    title: 'Hub',
    accent: 'open door',
    lede: 'Outreach, education, and what I do with the lab door open.',
    projects: byCategory('hub'),
    totalCount: allProjects.filter((p) => p.data.category === 'hub').length,
    soon: 'More community work landing here soon.',
  },
];

const publications = [
  {
    year: 2025,
    text: 'Efficacy of portable fugitive aerosol mitigation systems for nebulizer therapy during HFNC and NIV.',
    venue: 'Emergency Care and Medicine, 2(3), 36.',
  },
  {
    year: 2026,
    text: 'Development and validation of an optical sensor-based automated urine flow meter for real-time patient monitoring.',
  },
  {
    year: 2024,
    text: 'Commonly disrupted pathways in brain and kidney in a pig model of systemic endotoxemia.',
    venue: 'Journal of Neuroinflammation, 21(1), 9.',
  },
  {
    year: 2021,
    text: 'Self-contained system for mitigation of contaminated aerosol sources of SARS-CoV-2.',
    venue: "Master's thesis, ASU.",
  },
];
---

<Base>
  <nav class="site">
    <div class="mark">ADITHYA<span>_</span>SP</div>
    <ul>
      <li><a href={`${baseUrl}/lab`}>Lab</a></li>
      <li><a href={`${baseUrl}/side-quests`}>Side-quests</a></li>
      <li><a href={`${baseUrl}/hub`}>Hub</a></li>
      <li><a href={`${baseUrl}/off-hours`}>Off-hours</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="status-tag">AVAILABLE · 2026</div>
    <h1>Adithya<br /><span class="accent">Shyamala Pandian</span></h1>
    <div class="tagline">&gt; Electrical Engineer · Biomedical Sensor Researcher</div>
    <div class="meta">Tempe, AZ <span>◆</span> PhD @ ASU <span>◆</span> Sequitur Health</div>

    <div class="status-panel">
      <div class="status-item">
        <div class="label">Education</div>
        <div class="value">PhD<span class="unit">expected 2026</span></div>
        <div class="bar" style="--fill: 88%"></div>
      </div>
      <div class="status-item">
        <div class="label">Experience</div>
        <div class="value">7<span class="unit">years</span></div>
        <div class="bar" style="--fill: 70%"></div>
      </div>
      <div class="status-item">
        <div class="label">Publications</div>
        <div class="value">6<span class="unit">papers</span></div>
        <div class="bar" style="--fill: 55%"></div>
      </div>
      <div class="status-item">
        <div class="label">Patents</div>
        <div class="value">1<span class="unit">filed</span></div>
        <div class="bar" style="--fill: 35%"></div>
      </div>
    </div>
  </section>

  <section class="about" id="about">
    <div class="section-label"><span class="num">01</span>About</div>
    <h2 class="section-title">I build <span class="accent">mission-critical</span><br />biomedical sensors.</h2>
    <p>
      Hardware-algorithm co-designed CMOS imaging sensors for high-sensitivity biomarker detection. The kind of instruments that need to be right the first time, every time.
    </p>
    <p class="dim">
      PhD candidate at Arizona State University with Dr. Erica Forzani at the Biodesign Institute, in collaboration with Mayo Clinic and Sequitur Health. Previously co-founded Symbionic, building EEG-driven bionic prostheses in Chennai. I care about the meeting point of careful engineering and human consequence. And yes, I've built four Game Boys and four NES systems from scratch.
    </p>
  </section>

  {categoryBlocks.map((cat) => (
    <section class="category-block" id={cat.key}>
      <div class="cat-header">
        <div class="section-label"><span class="num">{cat.num}</span>{cat.label}</div>
        <a class="see-all" href={`${baseUrl}/${cat.key}`}>
          {cat.totalCount > 0 ? `See all ${cat.totalCount}` : 'See more'} →
        </a>
      </div>
      <h2 class="section-title">{cat.title.split(' ')[0]} {cat.title.split(' ').slice(1).join(' ')}{cat.title === 'Lab' ? '' : ''}.</h2>
      <p class="cat-lede">{cat.lede}</p>

      {cat.projects.length === 0 ? (
        <div class="empty-state">
          <div class="empty-pulse"></div>
          <p>{cat.soon}</p>
        </div>
      ) : (
        <div class="projects">
          {cat.projects.map((p) => (
            <a class="project" href={`${baseUrl}/${cat.key}/${p.id}`}>
              <div class="year">{p.data.year}{p.data.yearEnd ? `–${String(p.data.yearEnd).slice(-2)}` : ''}</div>
              <div>
                <div class="title">{p.data.title}</div>
                <div class="desc">{p.data.summary}</div>
                <div class="tags">
                  {p.data.tags.slice(0, 4).map((t) => <span>{t}</span>)}
                </div>
              </div>
              <div class="arrow">→</div>
            </a>
          ))}
        </div>
      )}
    </section>
  ))}

  <section class="category-block off-hours-teaser" id="off-hours">
    <div class="cat-header">
      <div class="section-label"><span class="num">05</span>Off-hours</div>
      <a class="see-all" href={`${baseUrl}/off-hours`}>See more →</a>
    </div>
    <h2 class="section-title">Off-<span class="accent">hours</span>.</h2>
    <p class="cat-lede">Outside the lab, outside the screen.</p>

    <a class="teaser-card" href={`${baseUrl}/off-hours`}>
      <div class="teaser-label">Country Swing</div>
      <p class="teaser-quote">
        "Howdy. When I ain't at the bench or wranglin' a side-quest, you'll likely find me at a country bar somewhere in the Valley."
      </p>
      <div class="teaser-cta">Step into the dance floor →</div>
    </a>
  </section>

  <div class="featured">
    <div class="label-row">
      <div class="section-label">★ Featured Build</div>
      <div class="badge">Showcase</div>
    </div>
    <h3>Four Game Boys and four NES systems, <span class="accent">built from scratch</span>.</h3>
    <p>
      Designed and showcased at ASU Open Door 2023 (Game Boys) and 2024 (NES). PCB design, firmware reverse-engineered, custom enclosures fabricated on the lab's drill press and SLA printers. Featured in ASU news coverage. The retro hardware is the through-line for everything I do: patient instruments and consumer hardware run on the same engineering discipline.
    </p>
    <p class="featured-link">
      <a href={`${baseUrl}/hub/nes-gameboy-builds`}>See the build →</a>
    </p>
    <div class="pixels">
      <div class="lit"></div><div class="lit"></div><div></div><div class="lit"></div><div></div><div class="lit"></div><div class="lit"></div><div></div>
      <div class="lit"></div><div></div><div class="lit"></div><div class="lit"></div><div class="lit"></div><div></div><div class="lit"></div><div class="lit"></div>
    </div>
  </div>

  <section class="pubs" id="writing">
    <div class="section-label"><span class="num">06</span>Writing</div>
    <h2 class="section-title">Peer-reviewed <span class="accent">publications</span>.</h2>
    <ul>
      {publications.map((p) => (
        <li>
          <span class="pub-year">{p.year}</span>
          <span>
            {p.text}
            {p.venue && <span class="pub-venue">{p.venue}</span>}
          </span>
        </li>
      ))}
    </ul>
  </section>

  <footer class="site" id="contact">
    <div class="saved">Last updated · May 2026</div>
    <div class="socials">
      <a href="https://github.com/spadithya">GitHub</a>
      <a href="#">Scholar</a>
      <a href="https://www.linkedin.com/in/adithya-shyamala-pandian">LinkedIn</a>
      <a href="mailto:adi@spadida.org">Email</a>
    </div>
  </footer>
</Base>

<style>
  .category-block { padding: 3.5rem 0 0; }
  .cat-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .see-all {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
    transition: color 0.2s, transform 0.2s;
  }
  .see-all:hover { color: var(--primary); }
  .cat-lede {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 1.5rem;
    max-width: 540px;
  }
  .empty-state {
    margin: 1rem 0 2rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px dashed var(--line-glow);
    text-align: center;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .empty-pulse {
    width: 10px;
    height: 10px;
    background: var(--primary);
    border-radius: 50%;
    margin: 0 auto 0.8rem;
    box-shadow: 0 0 10px var(--glow);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  .featured-link {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
  }
  .featured-link a {
    color: var(--accent);
    transition: color 0.2s;
  }
  .featured-link a:hover { color: var(--primary); }

  .teaser-card {
    display: block;
    margin: 1rem 0 0;
    padding: 1.8rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--line-glow);
    text-decoration: none;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
  }
  .teaser-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    background: linear-gradient(135deg, rgba(255, 179, 71, 0.06), transparent);
  }
  .teaser-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }
  .teaser-quote {
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.5;
    color: var(--text);
    font-style: italic;
    max-width: 640px;
    margin-bottom: 1rem;
  }
  .teaser-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--secondary);
    text-transform: uppercase;
  }
  .teaser-card:hover .teaser-cta {
    color: var(--primary);
  }
</style>
