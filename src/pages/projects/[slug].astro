---
import Base from '../../layouts/Base.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
const heroSrc = data.heroImage
  ? data.heroImage.startsWith('/')
    ? `${baseUrl}${data.heroImage}`
    : data.heroImage
  : null;
---

<Base title={`${data.title} · Adithya Shyamala Pandian`} description={data.summary}>
  <nav class="site">
    <div class="mark"><a href={import.meta.env.BASE_URL}>ADITHYA<span>_</span>SP</a></div>
    <ul>
      <li><a href={`${import.meta.env.BASE_URL}projects`}>Projects</a></li>
      <li><a href={`${import.meta.env.BASE_URL}#writing`}>Writing</a></li>
      <li><a href={`${import.meta.env.BASE_URL}#off-hours`}>Off-hours</a></li>
      <li><a href={`${import.meta.env.BASE_URL}#contact`}>Contact</a></li>
    </ul>
  </nav>

  <article class="project-detail">
    <div class="breadcrumb">
      <a href={`${import.meta.env.BASE_URL}projects`}>← All projects</a>
    </div>

    <header class="project-hero">
      <div class="meta-row">
        <span class="year-pill">{data.year}{data.yearEnd ? `–${data.yearEnd}` : ''}</span>
        <span class={`status status-${data.status}`}>{data.status}</span>
        <span class="category">{data.category}</span>
      </div>
      <h1 class="project-title">{data.title}</h1>
      <p class="project-summary">{data.summary}</p>
      <div class="tags">
        {data.tags.map((t) => <span>{t}</span>)}
      </div>
    </header>

    {heroSrc && (
      <figure class="hero-image">
        <img src={heroSrc} alt={`${data.title} hero image`} loading="eager" />
      </figure>
    )}

    <div class="facts-row">
      {data.role && (
        <div class="fact">
          <div class="fact-label">Role</div>
          <div class="fact-value">{data.role}</div>
        </div>
      )}
      {data.collaborators && data.collaborators.length > 0 && (
        <div class="fact">
          <div class="fact-label">Collaborators</div>
          <div class="fact-value">{data.collaborators.join(', ')}</div>
        </div>
      )}
      {data.funding && data.funding.length > 0 && (
        <div class="fact">
          <div class="fact-label">Funding</div>
          <div class="fact-value">{data.funding.join(', ')}</div>
        </div>
      )}
    </div>

    <div class="prose">
      <Content components={{ VideoEmbed, PhotoGallery }} />
    </div>

    {data.links && data.links.length > 0 && (
      <section class="links-section">
        <div class="section-label"><span class="num">▸</span>Links</div>
        <ul class="link-list">
          {data.links.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                <span>{link.label}</span>
                <span class="ext">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <footer class="site">
    <div class="saved">Last updated · May 2026</div>
    <div class="socials">
      <a href={import.meta.env.BASE_URL}>Home</a>
      <a href={`${import.meta.env.BASE_URL}projects`}>All projects</a>
      <a href="mailto:adi@spadida.org">Email</a>
    </div>
  </footer>
</Base>

<style>
  .project-detail {
    padding: 3rem 0 4rem;
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }
  .breadcrumb a {
    color: var(--muted);
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--primary); }

  .project-hero {
    margin-bottom: 3rem;
  }
  .meta-row {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .year-pill {
    color: var(--primary);
    border: 1px solid var(--primary);
    padding: 4px 10px;
  }
  .status {
    color: var(--muted);
    border: 1px solid var(--line);
    padding: 4px 10px;
  }
  .status-active { color: var(--secondary); border-color: var(--secondary); }
  .category {
    color: var(--muted);
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 60px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-bottom: 1.2rem;
  }
  .project-summary {
    font-size: 19px;
    line-height: 1.6;
    color: var(--text);
    max-width: 720px;
    margin-bottom: 1.5rem;
  }
  .project-hero .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .project-hero .tags span {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--secondary);
    border: 1px solid var(--line-glow);
    padding: 3px 8px;
    letter-spacing: 0.05em;
  }

  .hero-image {
    margin: 2.5rem 0;
    border: 1px solid var(--line-glow);
    background: var(--bg-card);
    overflow: hidden;
  }
  .hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .facts-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin: 2rem 0 3rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--line);
  }
  .fact-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }
  .fact-value {
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
  }

  /* MDX prose */
  .prose {
    max-width: 720px;
    font-size: 17px;
    line-height: 1.75;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .prose :global(h2::before) {
    content: '▸ ';
    color: var(--primary);
    font-size: 22px;
    margin-right: 0.3rem;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    margin: 1.8rem 0 0.6rem;
    color: var(--text);
  }
  .prose :global(p) {
    margin-bottom: 1.2rem;
    color: var(--text);
  }
  .prose :global(strong) {
    color: var(--primary);
    font-weight: 500;
  }
  .prose :global(em) {
    color: var(--secondary);
    font-style: italic;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 2px 6px;
    color: var(--secondary);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.2rem 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(a) {
    color: var(--primary);
    border-bottom: 1px solid var(--line-glow);
    transition: border-color 0.2s;
  }
  .prose :global(a:hover) {
    border-color: var(--primary);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }

  .links-section {
    margin: 3rem 0 0;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .link-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .link-list li {
    border-bottom: 1px solid var(--line);
  }
  .link-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text);
    transition: padding-left 0.2s, color 0.2s;
  }
  .link-list a:hover {
    padding-left: 0.8rem;
    color: var(--primary);
  }
  .link-list .ext {
    color: var(--muted);
    font-size: 14px;
  }

  @media (max-width: 700px) {
    .project-title { font-size: 36px; }
    .project-summary { font-size: 16px; }
  }
</style>
