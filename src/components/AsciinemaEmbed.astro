---
interface Props {
  id: string;
  caption?: string;
}

const { id, caption } = Astro.props;
---

<figure class="ascii-embed">
  <div class="ascii-frame">
    <script
      is:inline
      src={`https://asciinema.org/a/${id}.js`}
      id={`asciicast-${id}`}
      async
    ></script>
    <noscript>
      <a href={`https://asciinema.org/a/${id}`} target="_blank" rel="noopener noreferrer">
        Watch the demo on asciinema.org
      </a>
    </noscript>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .ascii-embed {
    margin: 2.5rem 0;
  }
  .ascii-frame {
    background: var(--bg-card);
    border: 1px solid var(--line-glow);
    padding: 0.5rem;
    overflow: auto;
    box-shadow: 0 0 24px rgba(91, 255, 133, 0.06);
  }
  figcaption {
    margin-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-align: center;
  }
</style>
